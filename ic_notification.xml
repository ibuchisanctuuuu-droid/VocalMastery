package com.sanctus.vocalmaster

import android.Manifest
import android.content.pm.PackageManager
import android.media.AudioFormat
import android.media.AudioRecord
import android.media.MediaRecorder
import android.os.Build
import android.os.Bundle
import android.widget.TimePicker
import androidx.appcompat.app.AppCompatActivity
import androidx.core.app.ActivityCompat
import androidx.core.content.ContextCompat
import com.sanctus.vocalmaster.audio.AudioAnalyzer
import com.sanctus.vocalmaster.audio.PitchDetector
import com.sanctus.vocalmaster.coach.CoachingEngine
import com.sanctus.vocalmaster.databinding.ActivityMainBinding
import com.sanctus.vocalmaster.notifications.ReminderManager
import kotlinx.coroutines.CoroutineScope
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.Job
import kotlinx.coroutines.launch
import kotlinx.coroutines.withContext

class MainActivity : AppCompatActivity() {

    private lateinit var binding: ActivityMainBinding
    private lateinit var coach: CoachingEngine
    private lateinit var reminderManager: ReminderManager
    private val pitchDetector = PitchDetector()
    private val analyzer = AudioAnalyzer()

    private var listeningJob: Job? = null
    private var audioRecord: AudioRecord? = null
    private val sampleRate = 44100

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        binding = ActivityMainBinding.inflate(layoutInflater)
        setContentView(binding.root)

        coach = CoachingEngine(this) { speaking ->
            runOnUiThread {
                binding.statusText.text = if (speaking) "Coach is talking..." else "Listening..."
            }
        }
        reminderManager = ReminderManager(this)

        binding.startListeningButton.setOnClickListener { requestMicAndStart() }
        binding.stopListeningButton.setOnClickListener { stopListening() }

        binding.setReminderButton.setOnClickListener {
            val hour = binding.reminderTimePicker.hour
            val minute = binding.reminderTimePicker.minute
            reminderManager.setDailyReminder(hour, minute)
            binding.statusText.text = "Daily reminder set for $hour:${minute.toString().padStart(2, '0')}"
        }

        binding.askTopicButton.setOnClickListener {
            val query = binding.topicInput.text.toString()
            if (query.isNotBlank()) {
                val explanation = coach.explainTopic(query)
                binding.lessonText.text = explanation
                coach.speakNow(explanation)
            }
        }
    }

    private fun requestMicAndStart() {
        if (ContextCompat.checkSelfPermission(this, Manifest.permission.RECORD_AUDIO)
            != PackageManager.PERMISSION_GRANTED
        ) {
            ActivityCompat.requestPermissions(this, arrayOf(Manifest.permission.RECORD_AUDIO), 100)
            return
        }
        startListening()
    }

    private fun startListening() {
        analyzer.reset()
        coach.speakNow(coach.openingLine())

        val minBufferSize = AudioRecord.getMinBufferSize(
            sampleRate, AudioFormat.CHANNEL_IN_MONO, AudioFormat.ENCODING_PCM_FLOAT
        )
        audioRecord = AudioRecord(
            MediaRecorder.AudioSource.MIC, sampleRate,
            AudioFormat.CHANNEL_IN_MONO, AudioFormat.ENCODING_PCM_FLOAT, minBufferSize
        )
        audioRecord?.startRecording()

        listeningJob = CoroutineScope(Dispatchers.Default).launch {
            val frame = FloatArray(2048)
            while (isActive()) {
                val read = audioRecord?.read(frame, 0, frame.size, AudioRecord.READ_BLOCKING) ?: 0
                if (read > 0) {
                    val pitch = pitchDetector.detectPitch(frame)
                    val volume = analyzer.rms(frame)
                    analyzer.pushFrame(pitch, volume)
                    val register = pitchDetector.estimateRegister(pitch)

                    val correction = coach.analyzeFrame(pitchDetector, analyzer, register)
                    if (correction != null) {
                        coach.speakNow(correction)
                    }

                    withContext(Dispatchers.Main) {
                        val (note, cents) = pitchDetector.frequencyToNote(pitch)
                        binding.pitchText.text = if (pitch > 0) "$note (${"%.1f".format(pitch)} Hz, ${cents}c) — $register" else "—"
                    }
                }
            }
        }
    }

    private fun isActive() = listeningJob?.isActive != false

    private fun stopListening() {
        listeningJob?.cancel()
        audioRecord?.stop()
        audioRecord?.release()
        audioRecord = null
        binding.statusText.text = "Stopped."
    }

    override fun onDestroy() {
        super.onDestroy()
        stopListening()
        coach.shutdown()
    }
}
